{
  "compilerOptions": {
    "outDir": "dist",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": true,

    "jsx": "react-jsx",

    "paths": {
      "@/*": ["./*"]
    },

    "allowJs": true,
    "isolatedModules": true,

    "noEmit": false   
  }
}